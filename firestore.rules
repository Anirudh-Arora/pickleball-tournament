rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tournaments: organizer can read/write; anyone can read published ones
    match /tournaments/{tournamentId} {
      allow read: if true;  // public read for participant page
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && resource.data.organizerId == request.auth.uid;
    }

    // Participants: anyone can create (register); only organizer can update/delete
    match /participants/{participantId} {
      allow read: if true;
      allow create: if true;  // public registration
      allow update, delete: if request.auth != null
        && get(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId)).data.organizerId == request.auth.uid;
    }

    // Teams: organizer-only write; public read
    match /teams/{teamId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId)).data.organizerId == request.auth.uid;
    }

    // Matches: organizer-only write; public read
    match /matches/{matchId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/tournaments/$(resource.data.tournamentId)).data.organizerId == request.auth.uid;
    }
  }
}
